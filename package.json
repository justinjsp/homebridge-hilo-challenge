{
  "name": "homebridge-hilo-challenge",
  "version": "0.1.2",
  "description": "Homebridge plugin for Hilo (Hydro-Québec) demand response challenges — exposes challenge phases as HomeKit contact sensors",
  "license": "MIT",
  "author": "Justin Prest",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinjsp/homebridge-hilo-challenge.git"
  },
  "bugs": {
    "url": "https://github.com/justinjsp/homebridge-hilo-challenge/issues"
  },
  "homepage": "https://github.com/justinjsp/homebridge-hilo-challenge#readme",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
